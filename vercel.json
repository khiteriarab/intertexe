{
  "env": {
    "HOMEPAGE_USE_FEED_CACHE": "1"
  },
  "buildCommand": "rm -rf .next && npx next build",
  "framework": "nextjs",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "crons": [
    {
      "path": "/api/cron/data-quality",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-collection-memberships",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/feed-sync-stale-alert",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/rakuten-feed-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-edit-preview",
      "schedule": "0 9 * * 4"
    },
    {
      "path": "/api/cron/weekly-edit-send",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/scan-followup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/notifications/price-drops",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/price-check",
      "schedule": "0 6 * * *"
    }
  ]
}
